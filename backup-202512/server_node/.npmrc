# pnpm 配置
# 使用 pnpm 作为包管理器
engine-strict=true

# 自动安装 peer dependencies
auto-install-peers=true

# 严格 peer dependencies
strict-peer-dependencies=false

# 使用符号链接（pnpm 的默认行为）
shamefully-hoist=false

# 存储位置（可选，使用默认值）
# store-dir=~/.pnpm-store

# 禁用资金提示
fund=false

# 禁用审计（可选，如果需要可以设置为 true）
audit=false

# 使用 pnpm 的严格模式
strict-peer-dependencies=false

# 确保只使用 pnpm
package-manager-strict=true
